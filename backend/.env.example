# ---- Server ----
NODE_ENV=development
PORT=3000

# 逗號分隔的允許來源；支援 exact origin 與 https://*.pages.dev / *.pages.dev
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Database ----
# Render / Supabase 等平台請貼上其提供的連線字串（需 sslmode=require）
DATABASE_URL=postgresql://user:password@localhost:5432/parts_task?schema=public

# ---- JWT ----
# 以 openssl rand -hex 48 產生，切勿共用兩把
JWT_ACCESS_SECRET=change_me_access_secret_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_secret_long_random_string
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# ---- Security ----
BCRYPT_ROUNDS=12

# ---- M3: Onshape OAuth（選填；未設定時 Onshape 功能停用）----
# 至 https://dev-portal.onshape.com 註冊 OAuth app 取得
ONSHAPE_CLIENT_ID=
ONSHAPE_CLIENT_SECRET=
# 須與 dev portal 的 Redirect URL 完全一致（本機預設值如下；正式環境填 Render 網址）
ONSHAPE_REDIRECT_URI=http://localhost:3000/api/v1/onshape/callback
# OAuth 完成後導回的前端網址（正式環境填 Cloudflare Pages 網址）
FRONTEND_URL=http://localhost:5173
# token 加密金鑰（選填，預設由 JWT_REFRESH_SECRET 衍生）
ONSHAPE_TOKEN_KEY=
