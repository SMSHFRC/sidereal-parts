{
  "name": "parts-task-backend",
  "version": "1.0.0",
  "description": "零件加工任務管理系統 — Production REST API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "prisma generate",
    "dev": "node --watch src/server.js",
