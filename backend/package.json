    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tarikjabiri/dxf": "^2.8.9",
    "bcryptjs": "^2.4.3",
