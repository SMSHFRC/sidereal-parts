// =========================================================
// 零件加工任務管理系統 — Prisma Schema (production)
// =========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  pending
  accepted
  processing
  post_processing
  pending_review
  completed
  rejected
  cancelled
}

enum MethodOccupancy {
  blocking
  automatic
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // 'admin' | 'member'
  users User[]

  @@map("roles")
}

model User {
  id           BigInt   @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  roleId       Int      @map("role_id")
  totalPoints  BigInt   @default(0) @map("total_points")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role              Role               @relation(fields: [roleId], references: [id])
  createdTasks      Task[]             @relation("Creator")
  assignedTasks     Task[]             @relation("Assignee")
  postProcessTasks  Task[]             @relation("PostProcessor")
  urgentMarkedTasks Task[]             @relation("UrgentMarkedBy")
  ownedPrintBatches PrintBatch[]        @relation("PrintBatchOwner")
  taskTransfersFrom TaskAssignmentTransfer[] @relation("TransferFromAssignee")
  taskTransfersTo   TaskAssignmentTransfer[] @relation("TransferToAssignee")
  taskTransfersBy   TaskAssignmentTransfer[] @relation("TransferChangedBy")
  onshapeAccount    OnshapeAccount?
  pointsLedger      UserPointsLedger[]
  sentTransfers     PointTransfer[]    @relation("TransferFrom")
  receivedTransfers PointTransfer[]    @relation("TransferTo")
  refreshTokens     RefreshToken[]
  onshapeImportBatches OnshapeImportBatch[]

  @@index([roleId])
  @@map("users")
}

model OnshapeImportBatch {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  sourceUrl String   @map("source_url")
  documentName String? @map("document_name")
  documentId String  @map("document_id")
  wvm       String
  wvmId     String   @map("wvm_id")
  elementId String   @map("element_id")
  summary   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
  cotsItems CotsItem[]

  @@index([userId])
  @@index([documentId, elementId])
  @@map("onshape_import_batches")
}

model CotsItem {
  id          BigInt   @id @default(autoincrement())
  batchId     BigInt   @map("batch_id")
  systemId    Int?     @map("system_id")
  robotId     BigInt?  @map("robot_id")
  subsystemId BigInt?  @map("subsystem_id")
  kind        String   @default("cots") // 'cots' | 'skipped'
  name        String?
  partNumber  String?  @map("part_number")
  quantity    Int      @default(0)
  collectedQuantity Int @default(0) @map("collected_quantity")
  isCollected Boolean  @default(false) @map("is_collected")
  collectedAt DateTime? @map("collected_at")
  material    String?
  note        String?
  sourceDocumentId String? @map("source_document_id")
  sourceElementId  String? @map("source_element_id")
  thumbnailUrl String? @map("thumbnail_url")
  raw         Json?
  createdAt   DateTime @default(now()) @map("created_at")

  batch OnshapeImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  system System? @relation(fields: [systemId], references: [id])
  robot Robot? @relation(fields: [robotId], references: [id])
  subsystem RobotSubsystem? @relation(fields: [subsystemId], references: [id])

  @@index([batchId])
  @@index([systemId])
  @@index([robotId])
  @@index([subsystemId])
  @@index([kind])
  @@index([isCollected])
  @@map("cots_items")
}

// M3：每位使用者的 Onshape OAuth 綁定（token 以 AES-256-GCM 加密存放）
model OnshapeAccount {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @unique @map("user_id")
  accessToken   String   @map("access_token") // 加密
  refreshToken  String   @map("refresh_token") // 加密
  expiresAt     DateTime @map("expires_at")
  onshapeUserId String?  @map("onshape_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onshape_accounts")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash") // 只存 hash，不存原始 token
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model System {
  id       Int     @id @default(autoincrement())
  code     String  @unique // 同時作為零件編號 prefix
  name     String
  isActive Boolean @default(true) @map("is_active")
  tasks    Task[]
  subsystems RobotSubsystem[]
  cotsItems CotsItem[]

  @@map("systems")
}

model Robot {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique
  name      String
  note      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subsystems RobotSubsystem[]
  tasks      Task[]
  cotsItems  CotsItem[]

  @@map("robots")
}

model RobotSubsystem {
  id        BigInt   @id @default(autoincrement())
  robotId   BigInt   @map("robot_id")
  systemId  Int?     @map("system_id")
  code      String
  name      String
  note      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  robot Robot @relation(fields: [robotId], references: [id], onDelete: Cascade)
  system System? @relation(fields: [systemId], references: [id])
  tasks Task[]
  cotsItems CotsItem[]

  @@unique([robotId, code])
  @@index([robotId])
  @@index([systemId])
  @@map("robot_subsystems")
}

model ManufacturingMethod {
  id             Int     @id @default(autoincrement())
  code           String  @unique
  name           String
  isActive       Boolean @default(true) @map("is_active")
  basePoints     Int     @default(5) @map("base_points") // 每件基礎積分
  requiresReview Boolean @default(false) @map("requires_review") // 完成需管理員驗收
  occupancy      MethodOccupancy @default(blocking)
  reminderMinutes Int    @default(30) @map("reminder_minutes")
  tasks          Task[]
  printBatches   PrintBatch[]

  @@map("manufacturing_methods")
}

model Material {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  name     String
  isActive Boolean @default(true) @map("is_active")
  tasks    Task[]

  @@map("materials")
}

model PostProcess {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  name     String
  isActive Boolean @default(true) @map("is_active")
  tasks    Task[]

  @@map("post_processes")
}

// 並發安全的流水號計數器（每個 prefix 一列）
model TaskNumberSequence {
  prefix    String @id
  lastValue BigInt @default(0) @map("last_value")

  @@map("task_number_sequences")
}

model Task {
  id                    BigInt     @id @default(autoincrement())
  partNumber            String     @map("part_number")
  partNumberPrefix      String     @map("part_number_prefix")
  partNumberSeq         BigInt     @map("part_number_seq")

  // 版本管理：同一 partNumber 可有多個 revision，只有一個 current，其餘 archived
  revision              Int        @default(1)
  revisionStatus        String     @default("current") @map("revision_status") // 'current' | 'archived'
  supersededById        BigInt?    @map("superseded_by_id") // 被哪個新版本取代（封存時回填）

  manufacturingMethodId Int        @map("manufacturing_method_id")
  systemId              Int        @map("system_id")
  robotId               BigInt?    @map("robot_id")
  subsystemId           BigInt?    @map("subsystem_id")
  materialId            Int?       @map("material_id")
  postProcessId         Int?       @map("post_process_id")

  creatorId             BigInt     @map("creator_id")
  assigneeId            BigInt?    @map("assignee_id")
  postProcessorId       BigInt?    @map("post_processor_id") // 後處理者（與加工者可為不同人）
  isUrgent              Boolean    @default(false) @map("is_urgent")
  urgentById            BigInt?    @map("urgent_by_id")
  urgentAt              DateTime?  @map("urgent_at")
  urgentReason          String?    @map("urgent_reason")

  quantity              Int
  rewardPoints          Int        @default(0) @map("reward_points")
  machiningExtensionMinutes Int    @default(0) @map("machining_extension_minutes")
  statusReminderSnoozedUntil DateTime? @map("status_reminder_snoozed_until")
  lastStatusReminderResponse String? @map("last_status_reminder_response")
  drawingUrl            String?    @map("drawing_url")

  // M3：Onshape 參照（由 drawingUrl 解析或零件選擇器帶入）
  onshapeDid    String? @map("onshape_did") // document id
  onshapeWvm    String? @map("onshape_wvm") // 'w' | 'v' | 'm'
  onshapeWvmId  String? @map("onshape_wvm_id") // workspace/version/microversion id
  onshapeEid    String? @map("onshape_eid") // element id
  onshapePartId String? @map("onshape_part_id") // 選到特定零件時
  onshapeConfig String? @map("onshape_config")
  onshapeRevision String? @map("onshape_revision")
  onshapeThumbnailUrl String? @map("onshape_thumbnail_url")
  onshapeImageMeta Json? @map("onshape_image_meta")
  importBatchId BigInt? @map("import_batch_id")
  dimensions            String?
  note                  String?
  status                TaskStatus @default(pending)

  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  manufacturingMethod ManufacturingMethod @relation(fields: [manufacturingMethodId], references: [id])
  system              System              @relation(fields: [systemId], references: [id])
  robot               Robot?              @relation(fields: [robotId], references: [id])
  subsystem           RobotSubsystem?     @relation(fields: [subsystemId], references: [id])
  material            Material?           @relation(fields: [materialId], references: [id])
  postProcess         PostProcess?        @relation(fields: [postProcessId], references: [id])
  creator             User                @relation("Creator", fields: [creatorId], references: [id])
  assignee            User?               @relation("Assignee", fields: [assigneeId], references: [id])
  postProcessor       User?               @relation("PostProcessor", fields: [postProcessorId], references: [id])
  urgentBy            User?               @relation("UrgentMarkedBy", fields: [urgentById], references: [id], onDelete: SetNull)
  statusHistory       TaskStatusHistory[]
  pointsLedger        UserPointsLedger[]
  importBatch         OnshapeImportBatch? @relation(fields: [importBatchId], references: [id])
  printBatchItems     PrintBatchTask[]
  assignmentTransfers TaskAssignmentTransfer[]

  @@unique([partNumber, revision])
  @@unique([partNumberPrefix, partNumberSeq, revision])
  @@index([partNumber])
  @@index([revisionStatus])
  @@index([assigneeId])
  @@index([postProcessorId])
  @@index([isUrgent])
  @@index([urgentById])
  @@index([creatorId])
  @@index([status])
  @@index([systemId])
  @@index([robotId])
  @@index([subsystemId])
  @@index([importBatchId])
  @@index([onshapeDid, onshapeEid, onshapePartId])
  @@map("tasks")
}

model PrintBatch {
  id                    BigInt     @id @default(autoincrement())
  manufacturingMethodId Int        @map("manufacturing_method_id")
  ownerId               BigInt     @map("owner_id")
  status                String     @default("processing")
  startedAt             DateTime   @default(now()) @map("started_at")
  completedAt           DateTime?  @map("completed_at")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  manufacturingMethod ManufacturingMethod @relation(fields: [manufacturingMethodId], references: [id])
  owner               User                @relation("PrintBatchOwner", fields: [ownerId], references: [id])
  items               PrintBatchTask[]

  @@index([manufacturingMethodId])
  @@index([ownerId])
  @@index([status])
  @@map("print_batches")
}

model PrintBatchTask {
  id        BigInt   @id @default(autoincrement())
  batchId   BigInt   @map("batch_id")
  taskId    BigInt   @map("task_id")
  addedBy   BigInt   @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  batch PrintBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  task  Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([batchId, taskId])
  @@index([taskId])
  @@index([addedBy])
  @@map("print_batch_tasks")
}

model TaskAssignmentTransfer {
  id              BigInt   @id @default(autoincrement())
  taskId          BigInt   @map("task_id")
  fromAssigneeId  BigInt?  @map("from_assignee_id")
  toAssigneeId    BigInt   @map("to_assignee_id")
  changedBy       BigInt   @map("changed_by")
  reason          String
  createdAt       DateTime @default(now()) @map("created_at")

  task         Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromAssignee User? @relation("TransferFromAssignee", fields: [fromAssigneeId], references: [id])
  toAssignee   User  @relation("TransferToAssignee", fields: [toAssigneeId], references: [id])
  changedByUser User @relation("TransferChangedBy", fields: [changedBy], references: [id])

  @@index([taskId])
  @@index([fromAssigneeId])
  @@index([toAssigneeId])
  @@map("task_assignment_transfers")
}

model TaskStatusHistory {
  id         BigInt     @id @default(autoincrement())
  taskId     BigInt     @map("task_id")
  fromStatus TaskStatus? @map("from_status")
  toStatus   TaskStatus @map("to_status")
  changedBy  BigInt     @map("changed_by")
  note       String?
  changedAt  DateTime   @default(now()) @map("changed_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_status_history")
}

model UserPointsLedger {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  taskId    BigInt?  @map("task_id")
  points    Int
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])

  // 同一任務對同一人、同一事由只發放一次
  // （加工分與後處理分事由不同，同一人兼任兩角色時可各領一次）
  @@unique([taskId, userId, reason])
  @@index([userId])
  @@map("user_points_ledger")
}

model PointTransfer {
  id         BigInt   @id @default(autoincrement())
  fromUserId BigInt   @map("from_user_id")
  toUserId   BigInt   @map("to_user_id")
  points     Int
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser   User @relation("TransferTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@map("point_transfers")
}
